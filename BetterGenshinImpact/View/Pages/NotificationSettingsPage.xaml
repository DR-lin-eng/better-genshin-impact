<!--  Email  -->
<ui:CardExpander Margin="0,0,0,12"
                 ContentPadding="0"
                 Icon="{ui:SymbolIcon Mail20}">
    <ui:CardExpander.Header>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock Grid.Row="0"
                         Grid.Column="0"
                         FontTypography="Body"
                         Text="启用邮件通知"
                         TextWrapping="Wrap" />
            <ui:TextBlock Grid.Row="1"
                         Grid.Column="0"
                         Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                         Text="邮件推送相关设置"
                         TextWrapping="Wrap" />
            <ui:ToggleSwitch Grid.Row="0"
                            Grid.RowSpan="2"
                            Grid.Column="1"
                            Margin="0,0,24,0"
                            IsChecked="{Binding Config.NotificationConfig.EmailEnabled, Mode=TwoWay}" />
        </Grid>
    </ui:CardExpander.Header>
    <StackPanel>
        <!-- SMTP服务器设置 -->
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock Grid.Row="0"
                         Grid.Column="0"
                         FontTypography="Body"
                         Text="SMTP服务器"
                         TextWrapping="Wrap" />
            <ui:TextBlock Grid.Row="1"
                         Grid.Column="0"
                         Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                         Text="填写SMTP服务器地址"
                         TextWrapping="Wrap" />
            <ui:TextBox Grid.Row="0"
                       Grid.RowSpan="2"
                       Grid.Column="1"
                       MinWidth="180"
                       MaxWidth="800"
                       Margin="0,0,36,0"
                       Text="{Binding SmtpServer, Mode=TwoWay}"
                       TextWrapping="NoWrap" />
        </Grid>

        <!-- SMTP端口 -->
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock Grid.Row="0"
                         Grid.Column="0"
                         FontTypography="Body"
                         Text="SMTP端口"
                         TextWrapping="Wrap" />
            <ui:TextBlock Grid.Row="1"
                         Grid.Column="0"
                         Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                         Text="填写SMTP端口(默认587)"
                         TextWrapping="Wrap" />
            <ui:NumberBox Grid.Row="0"
                         Grid.RowSpan="2"
                         Grid.Column="1"
                         MinWidth="180"
                         MaxWidth="800"
                         Margin="0,0,36,0"
                         Value="{Binding SmtpPort, Mode=TwoWay}" />
        </Grid>

        <!-- SMTP用户名 -->
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock Grid.Row="0"
                         Grid.Column="0"
                         FontTypography="Body"
                         Text="SMTP用户名"
                         TextWrapping="Wrap" />
            <ui:TextBlock Grid.Row="1"
                         Grid.Column="0"
                         Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                         Text="填写SMTP服务器用户名"
                         TextWrapping="Wrap" />
            <ui:TextBox Grid.Row="0"
                       Grid.RowSpan="2"
                       Grid.Column="1"
                       MinWidth="180"
                       MaxWidth="800"
                       Margin="0,0,36,0"
                       Text="{Binding SmtpUsername, Mode=TwoWay}"
                       TextWrapping="NoWrap" />
        </Grid>

        <!-- SMTP密码 -->
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock Grid.Row="0"
                         Grid.Column="0"
                         FontTypography="Body"
                         Text="SMTP密码"
                         TextWrapping="Wrap" />
            <ui:TextBlock Grid.Row="1"
                         Grid.Column="0"
                         Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                         Text="填写SMTP服务器密码"
                         TextWrapping="Wrap" />
            <ui:PasswordBox Grid.Row="0"
                           Grid.RowSpan="2"
                           Grid.Column="1"
                           MinWidth="180"
                           MaxWidth="800"
                           Margin="0,0,36,0"
                           Password="{Binding SmtpPassword, Mode=TwoWay}" />
        </Grid>

        <!-- 发件人设置 -->
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock Grid.Row="0"
                         Grid.Column="0"
                         FontTypography="Body"
                         Text="发件人邮箱"
                         TextWrapping="Wrap" />
            <ui:TextBlock Grid.Row="1"
                         Grid.Column="0"
                         Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                         Text="填写发件人邮箱地址"
                         TextWrapping="Wrap" />
            <ui:TextBox Grid.Row="0"
                       Grid.RowSpan="2"
                       Grid.Column="1"
                       MinWidth="180"
                       MaxWidth="800"
                       Margin="0,0,36,0"
                       Text="{Binding FromEmail, Mode=TwoWay}"
                       TextWrapping="NoWrap" />
        </Grid>

        <!-- 发件人名称 -->
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock Grid.Row="0"
                         Grid.Column="0"
                         FontTypography="Body"
                         Text="发件人名称"
                         TextWrapping="Wrap" />
            <ui:TextBlock Grid.Row="1"
                         Grid.Column="0"
                         Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                         Text="填写发件人显示名称"
                         TextWrapping="Wrap" />
            <ui:TextBox Grid.Row="0"
                       Grid.RowSpan="2"
                       Grid.Column="1"
                       MinWidth="180"
                       MaxWidth="800"
                       Margin="0,0,36,0"
                       Text="{Binding FromName, Mode=TwoWay}"
                       TextWrapping="NoWrap" />
        </Grid>

        <!-- 收件人邮箱 -->
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock Grid.Row="0"
                         Grid.Column="0"
                         FontTypography="Body"
                         Text="收件人邮箱"
                         TextWrapping="Wrap" />
            <ui:TextBlock Grid.Row="1"
                         Grid.Column="0"
                         Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                         Text="填写收件人邮箱地址"
                         TextWrapping="Wrap" />
            <ui:TextBox Grid.Row="0"
                       Grid.RowSpan="2"
                       Grid.Column="1"
                       MinWidth="180"
                       MaxWidth="800"
                       Margin="0,0,36,0"
                       Text="{Binding ToEmail, Mode=TwoWay}"
                       TextWrapping="NoWrap" />
        </Grid>

        <!-- 保存和测试按钮 -->
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock Grid.Row="0"
                         Grid.Column="0"
                         FontTypography="Body"
                         Text="测试"
                         TextWrapping="Wrap" />
            <ui:TextBlock Grid.Row="1"
                         Grid.Column="0"
                         Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                         Text="保存配置并发送测试邮件"
                         TextWrapping="Wrap" />
            <StackPanel Grid.Row="0"
                       Grid.Column="1"
                       Margin="0,0,36,0"
                       Orientation="Horizontal"
                       HorizontalAlignment="Right">
                <ui:Button Command="{Binding SaveEmailConfigCommand}"
                          Content="保存"
                          Margin="0,0,8,0"
                          IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}" />
                <ui:Button Command="{Binding TestEmailCommand}"
                          Content="发送测试"
                          IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}" />
            </StackPanel>
            <ui:TextBlock Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,0,36,0"
                         HorizontalAlignment="Right"
                         Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                         Text="{Binding EmailStatus}"
                         TextWrapping="Wrap" />
        </Grid>
    </StackPanel>
</ui:CardExpander>
